{
  "entities": {
    "Profile": {
      "title": "Student Profile",
      "description": "Academic status, XP, streak, and subjects for Rebound AI",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "displayName": {
          "type": "string",
          "description": "Student nickname or arcade moniker"
        },
        "cgpa": {
          "type": "number",
          "description": "Current cumulative GPA"
        },
        "prevCgpa": {
          "type": "number",
          "description": "Previous semester's CGPA for comparisons"
        },
        "cgpaHistory": {
          "type": "array",
          "description": "Array of objects representing previous semesters' CGPA logs"
        },
        "backlogs": {
          "type": "integer",
          "description": "Number of outstanding backlog courses"
        },
        "attendance": {
          "type": "number",
          "description": "Average attendance percentage"
        },
        "studyHours": {
          "type": "number",
          "description": "Weekly target study hours"
        },
        "confidenceLevel": {
          "type": "integer",
          "description": "Subjective academic confidence (1-10)"
        },
        "xp": {
          "type": "integer",
          "description": "Arcade XP points earned"
        },
        "streak": {
          "type": "integer",
          "description": "Consecutive days logging in"
        },
        "subjects": {
          "type": "string",
          "description": "Subjects list stored as a packed text or serialized array"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "displayName", "cgpa", "backlogs", "attendance", "studyHours", "confidenceLevel", "xp", "streak"]
    },
    "Journal": {
      "title": "Stress Journal",
      "description": "Student thermal scan of academic stress",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "stressLevel": {
          "type": "integer",
          "description": "Academic stress index (1-10)"
        },
        "analysis": {
          "type": "string",
          "description": "Gemini-powered evaluation of stress, confidence, and feedback"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "userId", "content", "stressLevel", "analysis", "createdAt"]
    },
    "RecoveryPlan": {
      "title": "AI Comeback Recovery Plan",
      "description": "Daily and weekly roadmap created by Gemini",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "planText": {
          "type": "string",
          "description": "Markdown recovery program generated by Gemini"
        },
        "dailyTasks": {
          "type": "string",
          "description": "JSON string representing daily checklist items"
        },
        "weeklyTasks": {
          "type": "string",
          "description": "JSON string representing weekly milestone assignments"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "planText", "dailyTasks", "weeklyTasks", "updatedAt"]
    },
    "AcademicTask": {
      "title": "Academic Comeback Task",
      "description": "A progress quest tracked by the student to gain XP",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "description": "attendance | backlog | exam | assignment | habit"
        },
        "done": {
          "type": "boolean"
        },
        "xpReward": {
          "type": "integer"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "userId", "title", "category", "done", "xpReward", "createdAt"]
    },
    "CoachChat": {
      "title": "Comeback Coach Conversation",
      "description": "Stored chat session logs with the AI Comeback Coach",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "messages": {
          "type": "string",
          "description": "JSON serialized chat dialogue array to prevent unbounded lists"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "userId", "messages", "updatedAt"]
    }
  },
  "firestore": {
    "profiles/{userId}": {
      "schema": "Profile",
      "description": "Individual student progress profiles and records"
    },
    "journals/{journalId}": {
      "schema": "Journal",
      "description": "Chronological Stress Log containing diagnostic evaluations"
    },
    "recoveryPlans/{userId}": {
      "schema": "RecoveryPlan",
      "description": "The current customized comeback regimen formulated by Gemini"
    },
    "tasks/{taskId}": {
      "schema": "AcademicTask",
      "description": "Individual student quests supporting their comeback efforts"
    },
    "coachChats/{userId}": {
      "schema": "CoachChat",
      "description": "Active session buffer mapping dialogues to users"
    }
  }
}
